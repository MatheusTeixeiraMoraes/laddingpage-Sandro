# Nao usada ainda -- o mapa atual usa o embed sem API key.
# Preencher quando a API JavaScript do Google Maps entrar (ver docs/superpowers/PENDENCIAS.md).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Project Settings -> API no painel do Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only -- NUNCA prefixar com NEXT_PUBLIC_, nunca commitar valor real,
# nunca usar em codigo que roda no navegador. So preencher quando o painel
# administrativo precisar de operacao que ignore RLS de proposito.
SUPABASE_SERVICE_ROLE_KEY=
